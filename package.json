{
  "name": "firebase-supabase-function-bridge",
  "version": "2.2.1",
  "description": "Bridge between Firebase Functions and Supabase HTTP triggers.",
  "main": "index.js",
  "author": "Jared Williams <accounts@jaredwilliams.com.au>",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^10.0.0",
    "pg": "^8.7.1"
  },
  "peerDependencies": {
    "firebase-admin": "*",
    "firebase-functions": "*"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^18.19.130",
    "@types/pg": "^8.20.0",
    "cross-env": "^10.1.0",
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.3.0",
    "jest": "^30.3.0",
    "prettier": "^2.3.2",
    "rimraf": "^6.1.3",
    "shx": "^0.4.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.2"
  },
  "bin": "bin/deploy",
  "scripts": {
    "prettier": "prettier \"src/**/*.js\" -w",
    "build": "shx rm -rf ./dist && tsc && shx cp package.json ./dist && shx cp -R ./bin ./dist && shx cp README.md ./dist && shx cp LICENSE.md ./dist && shx cp CHANGELOG.md ./dist",
    "test": "jest"
  },
  "engines": {
    "node": ">=18"
  },
  "types": "index.d.ts",
  "files": [
    "/*.js",
    "/*.d.ts",
    "/bin",
    "/*.md"
  ]
}